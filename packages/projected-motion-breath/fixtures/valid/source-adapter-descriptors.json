{
  "$schema": "rusty.manifold.projected_motion_breath.source_adapter_descriptors.v1",
  "descriptor_set_id": "descriptor_set.projected_motion_breath.source_adapters.synthetic",
  "package_id": "package.projected_motion_breath",
