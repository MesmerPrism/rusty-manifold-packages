{
  "$schema": "rusty.motion_breath_profile.v1",
  "profile_id": "profile.projected_motion_breath.headset_controller_fixed_orientation_state",
  "target_module_id": "module.breath.projected_motion",
  "input_kinds": [
    "pose"
  ],
  "projection": {
    "mode": "orientation_axis",
    "fallback_mode": "fixed_axis",
    "fixed_axis": [
      0.0,
      0.0,
      -1.0
    ]
  },
  "calibration": {
    "accepted_sample_count": 8,
    "min_accepted_delta": 0.0008,
    "min_span": 0.02,
    "lower_quantile": 0.05,
    "upper_quantile": 0.95
  },
  "normalization": {
    "soft_margin": 0.05,
    "edge_ease": 0.05,
    "progress_gamma": 1.0
  },
  "smoothing": {
    "analysis_rate_hz": 72.0,
    "median_window": 5,
    "ema_alpha": 0.18
  },
  "classifier": {
    "delta_threshold": 0.003,
    "stale_timeout_s": 1.0
  },
  "controller_state": {
    "mode": "fixed_controller_orientation",
    "orientation_axis": [
      0.0,
      0.0,
      -1.0
    ],
    "inhale_threshold": 0.001,
    "exhale_threshold": -0.00057,
    "rotation_guard_degrees": 0.5,
    "moving_average_guard": 0.025,
    "short_window": 24,
    "long_window": 180,
    "short_window_s": 0.3333333333333333,
    "long_window_s": 2.5,
    "invert_left_hand": true,
    "neutral_volume01": 0.5
  },
  "state_value": {
    "enabled": true,
    "min_value01": 0.0,
    "max_value01": 1.0,
    "initial_value01": 0.5,
    "fallback_value01": 0.5,
    "inhale_seconds_min_to_max": 4.0,
    "exhale_seconds_max_to_min": 4.0,
    "smoothing_s": 0.03,
    "stale_timeout_s": 1.0,
    "hold_bad_tracking": true
  },
  "quality": {
    "require_tracked": true,
    "min_quality01": 0.6
  }
}
